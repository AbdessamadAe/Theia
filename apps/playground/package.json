{
  "name": "@chalk/playground",
  "version": "0.1.0",
  "private": true,
  "description": "A zero-install browser playground for Chalk: edit .chalk, see the live deck, share by URL — all compiled client-side with the engine packages.",
  "type": "module",
  "scripts": {
    "prebuild": "node scripts/prebuild.mjs",
    "dev": "npm run prebuild && vite",
    "build": "npm run prebuild && vite build",
    "preview": "vite preview --port 5173 --strictPort",
    "typecheck": "tsc -p tsconfig.json"
  },
  "dependencies": {
    "@chalk/parser": "0.1.0",
    "@chalk/render-slides": "0.1.0",
    "@codemirror/language": "^6.10.0",
    "@codemirror/state": "^6.4.0",
    "@codemirror/view": "^6.34.0",
    "@fontsource/caveat": "^5.2.8",
    "@lezer/highlight": "^1.2.0",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-select": "^2.3.1",
    "@radix-ui/react-switch": "^1.3.1",
    "@radix-ui/react-tooltip": "^1.2.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "codemirror": "^6.0.1",
    "lz-string": "^1.5.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-resizable-panels": "^2.1.9",
    "tailwind-merge": "^3.6.0",
    "tailwindcss-animate": "^1.0.7"
  },
  "devDependencies": {
    "@types/react": "^18.3.31",
    "@types/react-dom": "^18.3.7",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.2",
    "fake-indexeddb": "^6.2.5",
    "postcss": "^8.5.15",
    "tailwindcss": "^3.4.19",
    "vite": "^5.4.0"
  }
}
