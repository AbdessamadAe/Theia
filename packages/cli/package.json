{
  "name": "theialang",
  "version": "0.1.0",
  "description": "Compile a math-teaching markup language (.theia) into self-contained, interactive HTML slide decks — live sliders, reactive KaTeX, 2D/3D scenes.",
  "type": "module",
  "bin": {
    "theia": "./dist/cli.js"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=20"
  },
  "license": "MIT",
  "author": "Abdessamad Ait Elmouden",
  "homepage": "https://github.com/AbdessamadAe/Theia#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/AbdessamadAe/Theia.git",
    "directory": "packages/cli"
  },
  "bugs": {
    "url": "https://github.com/AbdessamadAe/Theia/issues"
  },
  "keywords": [
    "theia",
    "slides",
    "presentation",
    "math",
    "mathematics",
    "katex",
    "latex",
    "interactive",
    "education",
    "teaching",
    "markdown",
    "lecture"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "node scripts/bundle.mjs",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "prepack": "node scripts/bundle.mjs"
  },
  "devDependencies": {
    "@theia/ast": "0.1.0",
    "@theia/parser": "0.1.0",
    "@theia/render-slides": "0.1.0",
    "esbuild": "^0.21.5"
  }
}
