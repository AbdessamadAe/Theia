{
  "name": "theia-monorepo",
  "version": "0.1.0",
  "private": true,
  "description": "Theia — compile a math-teaching markup language into interactive slide decks.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "packages/ast",
    "packages/parser",
    "packages/compute",
    "packages/runtime",
    "packages/render-slides",
    "packages/cli",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "build:app": "npm run build -w theia",
    "build:cli": "npm run build -w theialang",
    "typecheck": "npm run typecheck --workspaces --if-present",
    "test": "vitest run",
    "test:e2e": "node scripts/browser-test.mjs",
    "changeset": "changeset",
    "version-packages": "changeset version",
    "release": "npm run build && changeset publish",
    "clean": "rm -rf packages/*/dist"
  },
  "devDependencies": {
    "@changesets/cli": "^2.31.0",
    "@playwright/test": "^1.61.1",
    "@types/jsdom": "^28.0.3",
    "@types/node": "^20.14.0",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.4",
    "vitest": "^2.0.5"
  }
}
